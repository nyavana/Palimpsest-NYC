# ───────────────────────────── Environment ─────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ───────────────────────────── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/
*.egg
.ipynb_checkpoints/
.python-version
.uv/
uv.lock

# ───────────────────────────── Node / Vite ─────────────────────────────
node_modules/
dist/
.vite/
.turbo/
.parcel-cache/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────── Docker / data ───────────────────────────
.docker/
postgres-data/
redis-data/

# ───────────────────────────── Ingestion tiers ─────────────────────────
# Raw archives never leave the dev box and are never committed
data/raw/
data/bronze/
data/silver/
!data/**/.gitkeep

# ───────────────────────────── Meta-instrumentation ────────────────────
# Claude Code session logs are analysis data, not source
logs/
!logs/.gitkeep
!logs/claude-sessions/.gitkeep

# ───────────────────────────── IDE / OS ────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ───────────────────────────── Models / large files ────────────────────
*.gguf
*.bin
*.safetensors
models/
