# ─────────────────────────────────────────────────────────────
# Palimpsest NYC — example environment variables
# Copy to `.env` and fill in the blanks.
# ─────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── OpenRouter (cloud LLM) ──────────────────────────────────
# Required. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default: free Gemma-4 31B for dev. Flip to openai/gpt-5.4-mini and
# openai/gpt-5.4 for the paid eval / final-demo router cost analysis.
OPENROUTER_STANDARD_MODEL=google/gemma-4-31b-it:free
OPENROUTER_COMPLEX_MODEL=google/gemma-4-31b-it:free

# ── Local / "fast" LLM tier (OpenAI-compatible) ─────────────
# The router's `simple` complexity hits this URL+model. The naming is
# router-internal terminology — V1 always points this at OpenRouter, same as
# the cloud tier. The two-tier split exists so the router can run independent
# circuit breakers and so v2 can swap in an on-device endpoint without code
# change. On-device LLM hosting is explicitly out of scope for V1.
LOCAL_LLM_BASE_URL=https://openrouter.ai/api/v1
LOCAL_LLM_MODEL=google/gemma-4-31b-it:free
LOCAL_LLM_API_KEY=

# ── LLM router cache TTLs (seconds) ─────────────────────────
LLM_CACHE_TTL_SIMPLE_S=86400
LLM_CACHE_TTL_STANDARD_S=21600
LLM_CACHE_TTL_COMPLEX_S=3600

# ── LLM router circuit breaker ──────────────────────────────
LLM_CB_FAIL_THRESHOLD=3
LLM_CB_WINDOW_S=60
LLM_CB_COOLDOWN_S=30

# ── Embeddings ──────────────────────────────────────────────
# Sentence-transformers model loaded inside the api container. CPU-only.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32

# ── Postgres (PostGIS + pgvector + pg_trgm) ─────────────────
POSTGRES_USER=palimpsest
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=palimpsest
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
API_WORKERS=2

# ── Agent ───────────────────────────────────────────────────
AGENT_MAX_TURNS=6

# ── Meta-instrumentation ────────────────────────────────────
META_SESSION_LOG_DIR=/app/logs/claude-sessions

# ── Web frontend ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_MAP_ENGINE=maplibre
VITE_GOOGLE_MAP_TILES_API_KEY=
